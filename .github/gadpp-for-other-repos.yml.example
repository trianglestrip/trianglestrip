# 复制到其它项目仓库，例如 MiMo-CodeForMe：
#   .github/workflows/update-profile-page.yml
#
# 前置条件：在目标仓库 Settings → Secrets → Actions 添加
#   API_TOKEN_GITHUB = 有 repo 权限的 PAT
#
# 详见：https://github.com/umutphp/github-action-dynamic-profile-page

name: Update GitHub Profile Page
on: [push]

jobs:
  gadpp_job:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: umutphp/github-action-dynamic-profile-page@v5
        env:
          API_TOKEN_GITHUB: ${{ secrets.API_TOKEN_GITHUB }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          github-username: trianglestrip
          user-email: trianglestrip@gmail.com
